generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AccountType {
  SAVINGS
  CHECKING
  CURRENT
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  TRANSFER
  DEPOSIT
  WITHDRAWAL
  REVERSAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum Currency {
  USD
  EUR
  GBP
  INR
}

enum ScheduledStatus {
  PENDING
  EXECUTED
  FAILED
  CANCELLED
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum StandingStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isVerified   Boolean  @default(false) @map("is_verified")
  upiId        String?  @unique @map("upi_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  accounts             Account[]
  sessions             Session[]
  beneficiaries        Beneficiary[]
  auditLogs            AuditLog[]
  scheduledTransfers   ScheduledTransfer[]
  standingInstructions StandingInstruction[]
  @@map("users")
}

model Account {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  accountNumber String        @unique @map("account_number")
  accountType   AccountType   @map("account_type")
  balance       Decimal       @default(0) @db.Decimal(18, 2)
  currency      Currency      @default(INR)
  status        AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  user                         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions             Transaction[]         @relation("SenderAccount")
  receivedTransactions         Transaction[]         @relation("ReceiverAccount")
  linkedBeneficiaries          Beneficiary[]         @relation("BeneficiaryAccount")
  scheduledTransfersSent       ScheduledTransfer[]   @relation("ScheduledSender")
  scheduledTransfersReceived   ScheduledTransfer[]   @relation("ScheduledReceiver")
  standingInstructionsSent     StandingInstruction[] @relation("StandingSender")
  standingInstructionsReceived StandingInstruction[] @relation("StandingReceiver")
  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id                String            @id @default(uuid())
  senderAccountId   String?           @map("sender_account_id")
  receiverAccountId String?           @map("receiver_account_id")
  amount            Decimal           @db.Decimal(18, 2)
  transactionType   TransactionType   @map("transaction_type")
  description       String?
  status            TransactionStatus @default(PENDING)
  referenceNumber   String            @unique @map("reference_number")
  createdAt         DateTime          @default(now()) @map("created_at")
  senderAccount   Account? @relation("SenderAccount",   fields: [senderAccountId],   references: [id])
  receiverAccount Account? @relation("ReceiverAccount", fields: [receiverAccountId], references: [id])
  @@index([senderAccountId])
  @@index([receiverAccountId])
  @@index([createdAt])
  @@map("transactions")
}

model Beneficiary {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  beneficiaryName   String   @map("beneficiary_name")
  accountNumber     String   @map("account_number")
  bankName          String   @map("bank_name")
  ifscCode          String?  @map("ifsc_code")
  receiverAccountId String?  @map("receiver_account_id")
  isFavourite       Boolean  @default(false) @map("is_favourite")
  createdAt         DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId],            references: [id], onDelete: Cascade)
  receiverAccount Account? @relation("BeneficiaryAccount", fields: [receiverAccountId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([receiverAccountId])
  @@map("beneficiaries")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ScheduledTransfer {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  senderAccountId   String          @map("sender_account_id")
  receiverAccountId String          @map("receiver_account_id")
  amount            Decimal         @db.Decimal(18, 2)
  description       String?
  executeAt         DateTime        @map("execute_at")
  status            ScheduledStatus @default(PENDING)
  executedAt        DateTime?       @map("executed_at")
  transactionId     String?         @map("transaction_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  user            User    @relation(fields: [userId],            references: [id], onDelete: Cascade)
  senderAccount   Account @relation("ScheduledSender",  fields: [senderAccountId],   references: [id])
  receiverAccount Account @relation("ScheduledReceiver", fields: [receiverAccountId], references: [id])
  @@index([status, executeAt])
  @@index([userId])
  @@map("scheduled_transfers")
}

model StandingInstruction {
  id                String         @id @default(uuid())
  userId            String         @map("user_id")
  senderAccountId   String         @map("sender_account_id")
  receiverAccountId String         @map("receiver_account_id")
  amount            Decimal        @db.Decimal(18, 2)
  description       String?
  frequency         Frequency
  dayOfMonth        Int?           @map("day_of_month")
  nextRunAt         DateTime       @map("next_run_at")
  status            StandingStatus @default(ACTIVE)
  executionCount    Int            @default(0) @map("execution_count")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  user            User    @relation(fields: [userId],            references: [id], onDelete: Cascade)
  senderAccount   Account @relation("StandingSender",   fields: [senderAccountId],   references: [id])
  receiverAccount Account @relation("StandingReceiver",  fields: [receiverAccountId], references: [id])
  @@index([status, nextRunAt])
  @@index([userId])
  @@map("standing_instructions")
}
