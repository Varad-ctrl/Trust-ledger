{
  "info": {
    "name": "FinCore API — Phase 2",
    "description": "Complete authentication and banking API. Run Login first — tokens are auto-saved as collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "accountId",
      "value": ""
    },
    {
      "key": "userAccessToken",
      "value": ""
    },
    {
      "key": "adminTargetUserId",
      "value": ""
    },
    {
      "key": "adminTargetAccountId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const d = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken',  d.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
                  "  pm.collectionVariables.set('userId',       d.user.id);",
                  "  pm.test('Registration succeeded', () => pm.response.to.have.status(201));",
                  "  pm.test('Access token issued',    () => pm.expect(d.accessToken).to.be.a('string'));",
                  "  pm.test('Default account created',() => pm.expect(d.account.accountNumber).to.match(/^FC/));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@fincore.io\",\n  \"phone\": \"+91-9876543210\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "Register — duplicate email (should 409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@fincore.io\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "Register — weak password (should 422)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Weak\",\n  \"lastName\": \"Pass\",\n  \"email\": \"weak@fincore.io\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login — Deep Patel (seeded user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken',  d.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
                  "  pm.collectionVariables.set('userId',       d.user.id);",
                  "  pm.test('Login succeeded',      () => pm.response.to.have.status(200));",
                  "  pm.test('Tokens issued',         () => pm.expect(d.accessToken).to.be.a('string'));",
                  "  pm.test('User role is USER',     () => pm.expect(d.user.role).to.equal('USER'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"deep@fincore.io\",\n  \"password\": \"Demo@1234\"\n}"
            }
          }
        },
        {
          "name": "Login — Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken',  d.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
                  "  pm.test('Role is ADMIN', () => pm.expect(d.user.role).to.equal('ADMIN'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fincore.io\",\n  \"password\": \"Demo@1234\"\n}"
            }
          }
        },
        {
          "name": "Login — wrong password (should 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"deep@fincore.io\",\n  \"password\": \"WrongPassword1!\"\n}"
            }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken',  d.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
                  "  pm.test('New tokens issued', () => pm.expect(d.accessToken).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Get active sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/sessions",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Logout (current session)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout all devices",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout-all",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "1 — Login as Deep (saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('accessToken',  d.accessToken);",
                  "pm.collectionVariables.set('refreshToken', d.refreshToken);",
                  "pm.test('Login ok', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"deep@fincore.io\",\"password\":\"Demo@1234\"}"
            }
          }
        },
        {
          "name": "2 — GET /api/dashboard (Deep Patel)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK',                  () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('Has user object',         () => pm.expect(d.user).to.have.property('firstName'));",
                  "pm.test('No passwordHash leaked',  () => pm.expect(d.user.passwordHash).to.be.undefined);",
                  "pm.test('Has summary stats',       () => pm.expect(d.summary).to.have.all.keys('totalBalance','currency','accounts','beneficiaries','transactions'));",
                  "pm.test('totalBalance is string',  () => pm.expect(d.summary.totalBalance).to.be.a('string'));",
                  "pm.test('totalBalance has 2dp',    () => pm.expect(d.summary.totalBalance).to.match(/^\\d+\\.\\d{2}$/));",
                  "pm.test('Has accounts array',      () => pm.expect(d.accounts).to.be.an('array'));",
                  "pm.test('Has recentTransactions',  () => pm.expect(d.recentTransactions).to.be.an('array'));",
                  "pm.test('Max 5 recent txns',       () => pm.expect(d.recentTransactions.length).to.be.at.most(5));",
                  "if (d.recentTransactions.length) {",
                  "  const tx = d.recentTransactions[0];",
                  "  pm.test('Txn has direction field', () => pm.expect(tx.direction).to.be.oneOf(['SENT','RECEIVED','SELF']));",
                  "  pm.test('Txn amount is string',    () => pm.expect(tx.amount).to.be.a('string'));",
                  "  pm.test('Txn amount has 2dp',      () => pm.expect(tx.amount).to.match(/^\\d+\\.\\d{2}$/));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "3 — Login as Priya (different user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('accessToken', d.accessToken);",
                  "pm.test('Login ok', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"priya@fincore.io\",\"password\":\"Demo@1234\"}"
            }
          }
        },
        {
          "name": "4 — GET /api/dashboard (Priya Yadav — different data)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK',                () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('User is Priya',         () => pm.expect(d.user.firstName).to.equal('Priya'));",
                  "pm.test('Data is Priya's only', () => pm.expect(d.user.email).to.include('priya'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "5 — No token → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 without token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard"
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Get my profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Profile returned', () => pm.response.to.have.status(200));",
                  "pm.test('No password hash', () => pm.expect(pm.response.json().data.passwordHash).to.be.undefined);"
                ]
              }
