    {
      "name": "🔑 RBAC — Admin Panel",
      "item": [
        {
          "name": "Step 1 ► Login as USER (Deep Patel)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('userAccessToken',   d.accessToken);",
                  "pm.collectionVariables.set('userRefreshToken',  d.refreshToken);",
                  "pm.test('Logged in as USER', () => pm.expect(d.user.role).to.equal('USER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"deep@fincore.io\",\n  \"password\": \"Demo@1234\"\n}"
            }
          }
        },
        {
          "name": "Step 2 ► USER hits /admin/dashboard → expect 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden for USER', () => pm.response.to.have.status(403));",
                  "pm.test('Error message correct',  () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userAccessToken}}"
              }
            ]
          }
        },
        {
          "name": "Step 3 ► USER hits /admin/users → expect 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden for USER', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userAccessToken}}"
              }
            ]
          }
        },
