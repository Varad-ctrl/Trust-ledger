                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Step 7 ► ADMIN — Filter users by role=USER",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users?role=USER",
              "query": [
                {
                  "key": "role",
                  "value": "USER"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Step 8 ► ADMIN — Get single user with accounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK',           () => pm.response.to.have.status(200));",
                  "pm.test('Has accounts array', () => pm.expect(pm.response.json().data).to.have.property('accounts'));"
                ]
