          }
        },
        {
          "name": "Step 5 ► ADMIN — Dashboard",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK for ADMIN',       () => pm.response.to.have.status(200));",
                  "pm.test('Has users stats',        () => pm.expect(pm.response.json().data).to.have.property('users'));",
                  "pm.test('Has accounts stats',     () => pm.expect(pm.response.json().data).to.have.property('accounts'));",
                  "pm.test('Has transaction stats',  () => pm.expect(pm.response.json().data).to.have.property('transactions'));"
                ]
