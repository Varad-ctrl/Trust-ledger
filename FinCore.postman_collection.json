          }
        },
        {
          "name": "No auth header (should 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/profile"
          }
        }
      ]
    },
    {
      "name": "🏦 Accounts",
      "item": [
        {
          "name": "Get my accounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const accounts = pm.response.json().data;",
                  "  if (accounts.length) pm.collectionVariables.set('accountId', accounts[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get account by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts/{{accountId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Create new account",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/accounts",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountType\": \"CURRENT\",\n  \"currency\": \"INR\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "💸 Transactions",
      "item": [
        {
          "name": "Get my transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions?page=1&limit=10",
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Transfer funds (fill account IDs first)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions/transfer",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderAccountId\":   \"REPLACE_WITH_SENDER_ID\",\n  \"receiverAccountId\": \"REPLACE_WITH_RECEIVER_ID\",\n  \"amount\": 500,\n  \"description\": \"Test transfer\"\n}"
            }
          }
        }
      ]
    },
