            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Step 6 ► ADMIN — List all users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK',               () => pm.response.to.have.status(200));",
                  "pm.test('Pagination present',   () => pm.expect(pm.response.json().data).to.have.property('pagination'));",
                  "pm.test('No passwordHash',      () => {",
                  "  const users = pm.response.json().data.data;",
                  "  users.forEach(u => pm.expect(u.passwordHash).to.be.undefined);",
                  "});",
                  "if (pm.response.json().data.data.length) {",
                  "  pm.collectionVariables.set('adminTargetUserId', pm.response.json().data.data.find(u => u.role === 'USER')?.id || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
